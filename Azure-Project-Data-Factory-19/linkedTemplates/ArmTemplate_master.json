{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "Azure-Project-Data-Factory-19"
		},
		"ADLS_Connection_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_Connection'"
		},
		"Azure_SQL_DB_Connection_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Azure_SQL_DB_Connection'"
		},
		"ADLS_Connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://azureprojectstoragegroup.dfs.core.windows.net/"
		},
		"Azure_SQL_DB_Connection_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azure-project-server-1.database.windows.net"
		},
		"Azure_SQL_DB_Connection_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Azure_Project_DB"
		},
		"Azure_SQL_DB_Connection_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Sireesha_Admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "Azure-Project-Data-Factory-19_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_Connection_accountKey": {
						"value": "[parameters('ADLS_Connection_accountKey')]"
					},
					"Azure_SQL_DB_Connection_password": {
						"value": "[parameters('Azure_SQL_DB_Connection_password')]"
					},
					"ADLS_Connection_properties_typeProperties_url": {
						"value": "[parameters('ADLS_Connection_properties_typeProperties_url')]"
					},
					"Azure_SQL_DB_Connection_properties_typeProperties_server": {
						"value": "[parameters('Azure_SQL_DB_Connection_properties_typeProperties_server')]"
					},
					"Azure_SQL_DB_Connection_properties_typeProperties_database": {
						"value": "[parameters('Azure_SQL_DB_Connection_properties_typeProperties_database')]"
					},
					"Azure_SQL_DB_Connection_properties_typeProperties_userName": {
						"value": "[parameters('Azure_SQL_DB_Connection_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}